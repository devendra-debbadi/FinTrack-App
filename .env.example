# FinTrack — Docker Configuration
# ================================
# Copy this file to .env and customize as needed:
#   cp .env.example .env
#
# These values are used by docker-compose.yml for ALL services.
# You only need to edit THIS file — Docker handles the rest.

# MySQL Database
MYSQL_ROOT_PASSWORD=fintrack_root
MYSQL_DATABASE=fintrack_app
MYSQL_USER=fintrack
MYSQL_PASSWORD=fintrack_pass

# JWT Authentication (change this in production!)
JWT_SECRET=FinTrack_S3cur3_JWT_K3y_2026_Ch4ng3_Th1s_1n_Pr0d

# CORS — must match the URL you access the app from
CORS_ALLOWED_ORIGINS=http://localhost
